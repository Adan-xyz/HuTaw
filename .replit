modules = ["nodejs-20"]
[agent]
expertMode = true

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
mode = "sequential"
author = 31801279

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node src/hutaw.js"

[[workflows.workflow]]
name = "Deploy"
mode = "sequential"
author = 31801279

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node src/deploy-commands.js"

[[workflows.workflow]]
name = "Shard"
mode = "sequential"
author = 31801279

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node src/shard.js"

[[workflows.workflow]]
name = "Test"
mode = "sequential"
author = 31801279

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node test/index.js"
